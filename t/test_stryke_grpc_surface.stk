## t/test_stryke_grpc_surface.stk — wrapper-completeness pin.
##
## Asserts every public `fn X::Y::name` declared in lib/*.stk is
## reachable via `use` at runtime. Uses `exists &X::Y::name` to
## probe the symbol table without invoking the sub.
##
## Catches:
##   * a wrapper sub deleted from lib/ but still referenced elsewhere
##   * a sub-package file dropped from the install layout
##   * `use Foo::Bar` failing to chase into lib/Bar.stk
##   * an installed-package entry whose namespace bridge is broken
##
## Permission-free — no service, no creds, no live daemon. Private
## helpers (`_` prefix) are implementation detail and are NOT
## asserted, so refactoring internals stays free.

use Grpc

# ── Grpc.stk ──────────────────────────────────────────────
assert_ok exists &Grpc::version, "Grpc::version exists"
assert_ok exists &Grpc::ping, "Grpc::ping exists"
assert_ok exists &Grpc::list, "Grpc::list exists"
assert_ok exists &Grpc::describe, "Grpc::describe exists"
assert_ok exists &Grpc::call, "Grpc::call exists"
assert_ok exists &Grpc::server_stream, "Grpc::server_stream exists"
assert_ok exists &Grpc::client_stream, "Grpc::client_stream exists"
assert_ok exists &Grpc::bidi_stream, "Grpc::bidi_stream exists"

# ── pure helpers (no channel) ──
assert_ok exists &Grpc::parse_method, "Grpc::parse_method exists"
assert_ok exists &Grpc::parse_target, "Grpc::parse_target exists"
assert_ok exists &Grpc::build_target, "Grpc::build_target exists"
assert_ok exists &Grpc::parse_content_type, "Grpc::parse_content_type exists"
assert_ok exists &Grpc::build_content_type, "Grpc::build_content_type exists"
assert_ok exists &Grpc::parse_timeout, "Grpc::parse_timeout exists"
assert_ok exists &Grpc::build_timeout, "Grpc::build_timeout exists"
assert_ok exists &Grpc::build_method, "Grpc::build_method exists"
assert_ok exists &Grpc::is_binary_key, "Grpc::is_binary_key exists"
assert_ok exists &Grpc::valid_metadata_key, "Grpc::valid_metadata_key exists"
assert_ok exists &Grpc::normalize_metadata_key, "Grpc::normalize_metadata_key exists"
assert_ok exists &Grpc::valid_metadata_value, "Grpc::valid_metadata_value exists"
assert_ok exists &Grpc::encode_bin_value, "Grpc::encode_bin_value exists"
assert_ok exists &Grpc::decode_bin_value, "Grpc::decode_bin_value exists"
assert_ok exists &Grpc::status_codes, "Grpc::status_codes exists"
assert_ok exists &Grpc::status_description, "Grpc::status_description exists"
assert_ok exists &Grpc::encode_status_message, "Grpc::encode_status_message exists"
assert_ok exists &Grpc::decode_status_message, "Grpc::decode_status_message exists"
assert_ok exists &Grpc::http_status_for, "Grpc::http_status_for exists"
assert_ok exists &Grpc::grpc_status_for_http, "Grpc::grpc_status_for_http exists"
assert_ok exists &Grpc::parse_grpc_status, "Grpc::parse_grpc_status exists"
assert_ok exists &Grpc::build_grpc_trailer, "Grpc::build_grpc_trailer exists"
assert_ok exists &Grpc::parse_authority, "Grpc::parse_authority exists"
assert_ok exists &Grpc::parse_user_agent, "Grpc::parse_user_agent exists"
assert_ok exists &Grpc::build_user_agent, "Grpc::build_user_agent exists"
assert_ok exists &Grpc::is_reserved_key, "Grpc::is_reserved_key exists"
assert_ok exists &Grpc::split_full_method, "Grpc::split_full_method exists"
assert_ok exists &Grpc::compression_codecs, "Grpc::compression_codecs exists"
assert_ok exists &Grpc::valid_compression, "Grpc::valid_compression exists"
assert_ok exists &Grpc::parse_accept_encoding, "Grpc::parse_accept_encoding exists"
assert_ok exists &Grpc::build_accept_encoding, "Grpc::build_accept_encoding exists"
assert_ok exists &Grpc::health_status, "Grpc::health_status exists"
assert_ok exists &Grpc::build_authority, "Grpc::build_authority exists"
assert_ok exists &Grpc::is_pseudo_header, "Grpc::is_pseudo_header exists"
assert_ok exists &Grpc::retriable_status, "Grpc::retriable_status exists"
assert_ok exists &Grpc::frame_message, "Grpc::frame_message exists"
assert_ok exists &Grpc::unframe_message, "Grpc::unframe_message exists"

test_run
