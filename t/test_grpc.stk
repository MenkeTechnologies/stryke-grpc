## t/test_grpc.stk — assertion tests for the stryke `Grpc` package.
##
## Uses stryke's native test framework (`assert_*` + `test_run`).
## Requires the cdylib to be loaded — install once with `s pkg install -g .`
## so stryke's FFI bridge dlopens `lib/libstryke_grpc.{dylib,so}` on
## `use Grpc`. Live tests fire when $STRYKE_GRPC_TEST_TARGET points at a
## reflection-enabled gRPC server (set $STRYKE_GRPC_TEST_PLAINTEXT for
## non-TLS endpoints).

use Grpc

# ── permission-free: cdylib reachable ───────────────────────────────
val $version = Grpc::version()
assert_ok $version, "Grpc::version returns truthy (cdylib loaded)"

# ── live target ─────────────────────────────────────────────────────
val $target = $ENV{STRYKE_GRPC_TEST_TARGET}
if (defined $target && $target ne "") {
    var %conn = (target => $target)
    $conn{plaintext} = 1 if $ENV{STRYKE_GRPC_TEST_PLAINTEXT}

    if (Grpc::ping(%conn)) {
        # list services
        val @services = Grpc::list(%conn)
        assert_ge scalar(@services), 1, "list returns ≥1 service"

        # describe the first non-reflection service
        var $svc
        for val $row (@services) {
            next if $row->{service} =~ /^grpc\.reflection\./
            $svc = $row->{service}
            last
        }
        if (defined $svc) {
            val $info = Grpc::describe($svc, %conn)
            assert_eq ref($info->{methods}), "ARRAY", "describe returns methods array"
        }

        # call a unary method when $STRYKE_GRPC_TEST_METHOD is set
        val $method = $ENV{STRYKE_GRPC_TEST_METHOD}
        if (defined $method && $method ne "") {
            val $data = $ENV{STRYKE_GRPC_TEST_DATA} // "{}"
            val $reply = Grpc::call($method, from_json($data), %conn)
            assert_ok defined $reply, "call $method returns defined reply"
        }
    }
}

# ── pure helpers (no server needed — always run) ─────────────────────
val $nf = Grpc::status_code("NOT_FOUND")
assert_eq $nf->{code}, 5,           "status_code: NOT_FOUND is 5"
assert_eq $nf->{name}, "NOT_FOUND", "status_code: name echoed"
assert_eq Grpc::status_code(14)->{name}, "UNAVAILABLE", "status_code: numeric → name"
assert_eq Grpc::status_code("unavailable")->{code}, 14, "status_code: case-insensitive name"

# status_description: canonical one-line descriptions (by name or code).
val $nfd = Grpc::status_description("NOT_FOUND")
assert_eq $nfd->{code}, 5, "status_description: NOT_FOUND code"
assert_match qr/was not found/, $nfd->{description}, "status_description: verbatim text"
assert_match qr/transient/, Grpc::status_description(14)->{description}, "status_description: by numeric code (UNAVAILABLE)"
assert_dies fn { Grpc::status_description("NOPE") }, "status_description: rejects an unknown status"

# encode_status_message / decode_status_message: grpc-message percent codec.
assert_eq Grpc::encode_status_message("Not Found"), "Not Found", "encode_status_message: printable ASCII (incl. space) passes through"
assert_eq Grpc::encode_status_message("50% off"),   "50%25 off", "encode_status_message: % is encoded"
assert_eq Grpc::encode_status_message("a\tb"),      "a%09b",     "encode_status_message: control bytes → %XX uppercase"
assert_eq Grpc::decode_status_message("50%25 off"), "50% off",   "decode_status_message: inverts encode"
# Round-trips, including a non-ASCII message.
assert_eq Grpc::decode_status_message(Grpc::encode_status_message("héllo")), "héllo", "decode_status_message: round-trips UTF-8"
assert_eq Grpc::decode_status_message("100% done"), "100% done", "decode_status_message: a bad % escape stays literal"

val @codes = Grpc::status_codes()
assert_eq scalar(@codes), 17, "status_codes: 17 canonical codes"
assert_eq $codes[0]->{name}, "OK", "status_codes: OK is first"

# http_status_for: grpc-gateway gRPC→HTTP mapping (by name and by code).
assert_eq Grpc::http_status_for("NOT_FOUND")->{http_status}, 404, "http_status_for: NOT_FOUND → 404"
assert_eq Grpc::http_status_for(16)->{http_status}, 401, "http_status_for: UNAUTHENTICATED(16) → 401"
assert_eq Grpc::http_status_for("OK")->{http_status}, 200, "http_status_for: OK → 200"
assert_dies fn { Grpc::http_status_for("BOGUS") }, "http_status_for: rejects unknown status"

# grpc_status_for_http: gRPC spec HTTP→gRPC mapping (distinct table, not inverse).
val $g404 = Grpc::grpc_status_for_http(404)
assert_eq $g404->{name}, "UNIMPLEMENTED", "grpc_status_for_http: 404 → UNIMPLEMENTED"
assert_eq $g404->{code}, 12,              "grpc_status_for_http: 404 → code 12"
assert_eq Grpc::grpc_status_for_http(401)->{name}, "UNAUTHENTICATED", "grpc_status_for_http: 401 → UNAUTHENTICATED"
assert_eq Grpc::grpc_status_for_http(503)->{name}, "UNAVAILABLE",     "grpc_status_for_http: 503 → UNAVAILABLE"
assert_eq Grpc::grpc_status_for_http(504)->{name}, "DEADLINE_EXCEEDED", "grpc_status_for_http: 504 → DEADLINE_EXCEEDED"
assert_eq Grpc::grpc_status_for_http(500)->{name}, "UNKNOWN", "grpc_status_for_http: other → UNKNOWN"

# parse_timeout: grpc-timeout header (case-sensitive units).
val $to = Grpc::parse_timeout("100m")
assert_eq $to->{unit_name}, "Millisecond", "parse_timeout: 100m is milliseconds"
assert_eq $to->{nanos},     100000000,     "parse_timeout: 100ms in nanos"
assert_eq $to->{seconds},   0.1,           "parse_timeout: 100ms in seconds"
assert_eq Grpc::parse_timeout("5M")->{nanos}, 300000000000, "parse_timeout: 5M is 5 minutes"
assert_eq Grpc::parse_timeout("5m")->{nanos}, 5000000,      "parse_timeout: 5m is 5 milliseconds (case matters)"
assert_eq Grpc::parse_timeout("30S")->{unit_name}, "Second", "parse_timeout: S is Second"
assert_dies fn { Grpc::parse_timeout("100x") }, "parse_timeout: rejects an unknown unit"

# build_timeout: inverse — encode nanos as a grpc-timeout header value.
assert_eq Grpc::build_timeout(0)->{timeout},   "0n",       "build_timeout: zero is 0n"
assert_eq Grpc::build_timeout(250)->{timeout}, "250n",     "build_timeout: 250ns stays nanoseconds"
assert_eq Grpc::build_timeout(100000000)->{timeout}, "100000u", "build_timeout: 100ms steps up to microseconds (8-digit cap)"
assert_eq Grpc::build_timeout(300000000000)->{timeout}, "300000m", "build_timeout: 5 minutes is 300000m (finest unit ≤ 8 digits)"
assert_eq Grpc::build_timeout(100000001)->{timeout}, "100001u", "build_timeout: rounds up when stepping unit (100000001ns → 100001u)"
assert_eq Grpc::parse_timeout(Grpc::build_timeout(30000000000)->{timeout})->{nanos}, 30000000000, "build_timeout: round-trips through parse_timeout"
assert_dies fn { Grpc::build_timeout() }, "build_timeout: requires nanos"

val $pm = Grpc::parse_method("/grpc.health.v1.Health/Check")
assert_eq $pm->{package}, "grpc.health.v1", "parse_method: dotted package"
assert_eq $pm->{service}, "Health",         "parse_method: service"
assert_eq $pm->{method},  "Check",          "parse_method: method"

# parse_target: decompose a gRPC channel target URI per gRPC name resolution.
val $tb = Grpc::parse_target("localhost:50051")
assert_eq $tb->{scheme}, "dns",         "parse_target: no scheme → dns default"
assert_ok $tb->{default_scheme},        "parse_target: default_scheme flag set"
assert_eq $tb->{endpoint}, "localhost:50051", "parse_target: bare endpoint"
val $td = Grpc::parse_target("dns://8.8.8.8/my.service.com")
assert_eq $td->{authority}, "8.8.8.8",  "parse_target: dns authority lifted"
assert_eq $td->{endpoint}, "my.service.com", "parse_target: dns endpoint after authority"
assert_eq Grpc::parse_target("unix:///tmp/abs.sock")->{endpoint}, "/tmp/abs.sock", "parse_target: unix:/// absolute path"
val $tv4 = Grpc::parse_target("ipv4:1.2.3.4:50051,5.6.7.8")
assert_eq $tv4->{addresses}[0]{port}, 50051, "parse_target: ipv4 explicit port"
assert_eq $tv4->{addresses}[1]{port}, 443,   "parse_target: ipv4 default port 443"
val $tv6 = Grpc::parse_target("ipv6:[2607:f8b0::ef]:8080")
assert_eq $tv6->{addresses}[0]{address}, "2607:f8b0::ef", "parse_target: ipv6 bracketed address"
assert_eq $tv6->{addresses}[0]{port}, 8080, "parse_target: ipv6 port"

# build_target: the inverse of parse_target — construct a canonical target string.
assert_eq Grpc::build_target(endpoint => "localhost:50051")->{target}, "dns:localhost:50051", "build_target: dns bare endpoint"
assert_eq Grpc::build_target(scheme => "dns", authority => "8.8.8.8", endpoint => "my.service.com")->{target}, "dns://8.8.8.8/my.service.com", "build_target: dns authority"
assert_eq Grpc::build_target(scheme => "unix", endpoint => "/tmp/abs.sock")->{target}, "unix:///tmp/abs.sock", "build_target: unix absolute path"
assert_eq Grpc::build_target(scheme => "unix-abstract", endpoint => "my-socket")->{target}, "unix-abstract:my-socket", "build_target: unix-abstract"
assert_eq Grpc::build_target(scheme => "ipv6", addresses => [+{ address => "::1", port => 443 }])->{target}, "ipv6:[::1]:443", "build_target: ipv6 bracketed with port"
# round-trip through parse_target
val $rt = Grpc::parse_target(Grpc::build_target(scheme => "ipv4", addresses => [+{ address => "1.2.3.4", port => 50051 }])->{target})
assert_eq $rt->{addresses}[0]{port}, 50051, "build_target: round-trips through parse_target"
assert_dies fn { Grpc::build_target(scheme => "dns") }, "build_target: missing endpoint dies"

# parse_content_type: extract the gRPC message codec from the content-type header.
val $ct = Grpc::parse_content_type("application/grpc+json")
assert_ok $ct->{valid},        "parse_content_type: application/grpc+json is valid"
assert_eq $ct->{codec}, "json", "parse_content_type: extracts the json codec"
assert_eq Grpc::parse_content_type("application/grpc")->{codec},   "proto", "parse_content_type: bare form defaults to proto"
assert_eq Grpc::parse_content_type("application/grpc")->{default}, 1,       "parse_content_type: bare form sets the default flag"
assert_eq Grpc::parse_content_type("application/grpc-web")->{valid}, 0, "parse_content_type: gRPC-Web is a different protocol → invalid"
assert_eq Grpc::parse_content_type("application/json")->{valid},    0, "parse_content_type: a non-grpc type is invalid"

# build_content_type: inverse of parse_content_type.
assert_eq Grpc::build_content_type()->{content_type}, "application/grpc", "build_content_type: no codec → bare default form"
assert_eq Grpc::build_content_type(codec => "json")->{content_type}, "application/grpc+json", "build_content_type: explicit codec → +codec form"
assert_eq Grpc::build_content_type(codec => "proto", default => 1)->{content_type}, "application/grpc", "build_content_type: default flag forces the bare form"
val $rtj = Grpc::parse_content_type("application/grpc+json")
assert_eq Grpc::build_content_type(codec => $rtj->{codec}, default => $rtj->{default})->{content_type}, "application/grpc+json", "build_content_type: round-trips a parsed header"
assert_dies fn { Grpc::build_content_type(codec => "a b") }, "build_content_type: rejects a non-token codec"

# build_method: inverse of parse_method.
assert_eq Grpc::build_method(package => "grpc.health.v1", service => "Health", method => "Check")->{path}, "/grpc.health.v1.Health/Check", "build_method: dotted package path"
assert_eq Grpc::build_method(service => "Health", method => "Check")->{path}, "/Health/Check", "build_method: no package → bare service"
assert_dies fn { Grpc::build_method(method => "Check") }, "build_method: missing service errors"

assert_eq Grpc::is_binary_key("trace-bin"), 1,  "is_binary_key: -bin suffix"
assert_eq Grpc::is_binary_key("x-api-key"), 0, "is_binary_key: ascii key"

# valid_metadata_key: Custom-Metadata grammar (lowercase/digit/_-., grpc- reserved).
assert_ok Grpc::valid_metadata_key("x-api-key")->{valid},   "valid_metadata_key: allowed name"
assert_ok Grpc::valid_metadata_key("trace-bin")->{binary},  "valid_metadata_key: reports -bin binary flag"
assert_eq Grpc::valid_metadata_key("X-Caps")->{valid}, 0,   "valid_metadata_key: rejects uppercase"
assert_eq Grpc::valid_metadata_key("grpc-status")->{valid}, 0, "valid_metadata_key: grpc- prefix reserved"
assert_eq Grpc::valid_metadata_key("has space")->{valid}, 0, "valid_metadata_key: rejects spaces"

# normalize_metadata_key: canonical lowercase wire form (keys are case-insensitive).
val $nm = Grpc::normalize_metadata_key("Content-Type")
assert_eq $nm->{normalized}, "content-type", "normalize_metadata_key: lowercases the key"
assert_eq $nm->{changed},    1,              "normalize_metadata_key: flags the case change"
assert_eq Grpc::normalize_metadata_key("x-api-key")->{changed}, 0, "normalize_metadata_key: already-canonical is unchanged"
assert_ok Grpc::normalize_metadata_key("Trace-BIN")->{binary}, "normalize_metadata_key: detects -bin after lowercasing"
assert_dies fn { Grpc::normalize_metadata_key() }, "normalize_metadata_key: dies without a key"

# valid_metadata_value: ASCII keys take printable ASCII, -bin keys take base64.
# `\@` escapes the at-sign so stryke does not array-interpolate it.
assert_ok Grpc::valid_metadata_value("authorization", "Bearer abc123")->{valid}, "valid_metadata_value: printable ASCII passes"
assert_eq Grpc::valid_metadata_value("x-note", "line1\nline2")->{valid}, 0, "valid_metadata_value: control byte rejected"
assert_ok Grpc::valid_metadata_value("trace-bin", "aGk=")->{valid},  "valid_metadata_value: padded base64 for -bin"
assert_ok Grpc::valid_metadata_value("trace-bin", "aGk")->{valid},   "valid_metadata_value: un-padded base64 accepted"
assert_eq Grpc::valid_metadata_value("trace-bin", "aG*=")->{valid}, 0, "valid_metadata_value: non-base64 char rejected for -bin"
assert_ok Grpc::valid_metadata_value("x-note-bin", "v\@l")->{binary}, "valid_metadata_value: reports binary flag from -bin key"

# encode_bin_value / decode_bin_value: -bin metadata base64 wire codec.
assert_eq Grpc::encode_bin_value("hi"),  "aGk=", "encode_bin_value: padded base64"
assert_eq Grpc::encode_bin_value("Man"), "TWFu", "encode_bin_value: 3 bytes, no padding"
assert_eq Grpc::decode_bin_value("aGk="), "hi",  "decode_bin_value: inverts encode"
assert_eq Grpc::decode_bin_value("aGk"),  "hi",  "decode_bin_value: accepts un-padded base64"
assert_eq Grpc::decode_bin_value(Grpc::encode_bin_value("the quick brown fox")), "the quick brown fox", "decode_bin_value: round-trips encode_bin_value"
# The encoded form is itself a valid -bin metadata value.
assert_ok Grpc::valid_metadata_value("trace-bin", Grpc::encode_bin_value("payload"))->{valid}, "encode_bin_value: output passes valid_metadata_value"
assert_dies fn { Grpc::decode_bin_value("aG*=") }, "decode_bin_value: rejects a non-base64 character"

# encode_metadata_value: key-aware wire encoding (base64 for -bin, ASCII passthrough else).
val $mb = Grpc::encode_metadata_value("trace-bin", "Man")
assert_eq $mb->{binary}, 1,        "encode_metadata_value: -bin key is binary"
assert_eq $mb->{encoded}, "TWFu",  "encode_metadata_value: -bin key base64-encodes"
val $mt = Grpc::encode_metadata_value("user-agent", "grpc/1.0")
assert_eq $mt->{binary}, 0,           "encode_metadata_value: text key is not binary"
assert_eq $mt->{encoded}, "grpc/1.0", "encode_metadata_value: text key passes ASCII through verbatim"
# a -bin key accepts non-ASCII bytes; a text key rejects them.
assert_eq Grpc::encode_metadata_value("x-data-bin", "café")->{binary}, 1, "encode_metadata_value: -bin key accepts non-ASCII"
assert_dies fn { Grpc::encode_metadata_value("x-data", "café") }, "encode_metadata_value: text key rejects a non-ASCII value"
assert_dies fn { Grpc::encode_metadata_value("x", "a\rb") }, "encode_metadata_value: text key rejects a control char (no CRLF injection)"

test_run
