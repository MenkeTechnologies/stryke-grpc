## t/test_grpc.stk — assertion tests for the stryke `Grpc` package.
##
## Uses stryke's native test framework (`assert_*` + `test_run`).
## Requires the cdylib to be loaded — install once with `s pkg install -g .`
## so stryke's FFI bridge dlopens `lib/libstryke_grpc.{dylib,so}` on
## `use Grpc`. Live tests fire when $STRYKE_GRPC_TEST_TARGET points at a
## reflection-enabled gRPC server (set $STRYKE_GRPC_TEST_PLAINTEXT for
## non-TLS endpoints).

use Grpc

# ── permission-free: cdylib reachable ───────────────────────────────
val $version = Grpc::version()
assert_ok $version, "Grpc::version returns truthy (cdylib loaded)"

# ── live target ─────────────────────────────────────────────────────
val $target = $ENV{STRYKE_GRPC_TEST_TARGET}
if (defined $target && $target ne "") {
    var %conn = (target => $target)
    $conn{plaintext} = 1 if $ENV{STRYKE_GRPC_TEST_PLAINTEXT}

    if (Grpc::ping(%conn)) {
        # list services
        val @services = Grpc::list(%conn)
        assert_ge scalar(@services), 1, "list returns ≥1 service"

        # describe the first non-reflection service
        var $svc
        for val $row (@services) {
            next if $row->{service} =~ /^grpc\.reflection\./
            $svc = $row->{service}
            last
        }
        if (defined $svc) {
            val $info = Grpc::describe($svc, %conn)
            assert_eq ref($info->{methods}), "ARRAY", "describe returns methods array"
        }

        # call a unary method when $STRYKE_GRPC_TEST_METHOD is set
        val $method = $ENV{STRYKE_GRPC_TEST_METHOD}
        if (defined $method && $method ne "") {
            val $data = $ENV{STRYKE_GRPC_TEST_DATA} // "{}"
            val $reply = Grpc::call($method, from_json($data), %conn)
            assert_ok defined $reply, "call $method returns defined reply"
        }
    }
}

test_run
